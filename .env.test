# growatt-bridge integration test configuration
# Points to the public Growatt test server using the publicly known 2016 demo token.
#
# WARNING: Do NOT replace these values with your real credentials.
# This file is intentionally committed because it contains only the public
# demo token (published in Growatt's 2016 developer PDF).
# Create a separate .env file for production credentials — it is gitignored.

# Public demo token from Growatt's 2016 OpenAPI PDF — not a secret.
GROWATT_API_TOKEN=6eb6f069523055a339d71e5b1f6c88cc

# Growatt public test/demo server (speaks same OpenAPI V1 protocol as openapi.growatt.com)
GROWATT_SERVER_URL=https://test.growatt.com/

# Safety net: block any write path even if the script has a bug
BRIDGE_READONLY=true

# Use a different port to avoid clashing with a running dev instance
BRIDGE_PORT=8082
