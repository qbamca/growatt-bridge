# growatt-bridge environment variables
# Copy to .env and fill in your values.

# ── Required ──────────────────────────────────────────────────────────────────
# OpenAPI V1 token: ShinePhone app → Me → account name → API Token
GROWATT_API_TOKEN=

# ── Optional: Growatt Cloud ───────────────────────────────────────────────────
# Regional server URL. Defaults to EU endpoint.
# EU (default): https://openapi.growatt.com/
# China:        https://openapi-cn.growatt.com/
# North America: https://openapi-us.growatt.com/
# GROWATT_SERVER_URL=https://openapi.growatt.com/

# Default device serial number (skip discovery in single-device setups)
# GROWATT_DEVICE_SN=

# Default plant ID
# GROWATT_PLANT_ID=

# ── Optional: Legacy Shine web writes (when OpenAPI tlxSet returns 10002) ────
# When true, all MIN parameter + time-segment writes use POST .../tcpSet.do
# with Shine portal login instead of OpenAPI v1/tlxSet.
# GROWATT_LEGACY_WEB_MIN_WRITES=false
# GROWATT_WEB_BASE_URL=https://server.growatt.com/
# GROWATT_WEB_USERNAME=
# GROWATT_WEB_PASSWORD=

# ── Optional: Bridge Behavior ─────────────────────────────────────────────────
# Root log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO).
# Set to DEBUG to include telemetry/legacy JSON error body previews in logs.
# BRIDGE_LOG_LEVEL=INFO

# HTTP port (default: 8081)
# BRIDGE_PORT=8081

# Bind address (default: 0.0.0.0)
# BRIDGE_HOST=0.0.0.0

# Disable all writes. Set to false to enable writes (also requires BRIDGE_WRITE_ALLOWLIST).
# BRIDGE_READONLY=true

# Comma-separated list of allowed write operation IDs.
# Empty = no writes permitted even if BRIDGE_READONLY=false.
# Valid IDs: set_ac_charge_stop_soc, set_ac_charge_enable,
# set_on_grid_discharge_stop_soc, set_time_segment
# BRIDGE_WRITE_ALLOWLIST=

# Maximum write operations per minute (default: 3)
# BRIDGE_RATE_LIMIT_WRITES=3

# Re-read config after every write to verify the change took effect (default: true)
# BRIDGE_REQUIRE_READBACK=true

# Path for the append-only audit log (default: /var/log/growatt-bridge/audit.jsonl)
# BRIDGE_AUDIT_LOG=/var/log/growatt-bridge/audit.jsonl
