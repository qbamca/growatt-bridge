# Growatt Cloud API Explorer - Environment Variables
# Copy to .env and fill with your credentials.

# Legacy API (ShinePhone) - username/password from ShinePhone/dashboard
GROWATT_USERNAME=
GROWATT_PASSWORD=

# OpenAPI V1 - token from ShinePhone app: Me > account name > API Token
GROWATT_API_TOKEN=

# Optional: regional server override
# EU (default): https://openapi.growatt.com/
# China: https://openapi-cn.growatt.com/
# North America: https://openapi-us.growatt.com/
# GROWATT_SERVER_URL=https://openapi.growatt.com/
